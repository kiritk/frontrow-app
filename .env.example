# Mapbox tokens — copy this file to `.env` and fill in real values.
# Get tokens at https://account.mapbox.com/access-tokens/

# Public token (pk.*) — used at runtime. Safe to expose in the client app.
EXPO_PUBLIC_MAPBOX_PUBLIC_TOKEN=pk.REPLACE_ME

# Secret download token (sk.* with DOWNLOADS:READ scope) — used only at build
# time by the @rnmapbox/maps config plugin to download the native SDK.
# For EAS builds, set this via `eas secret:create --name MAPBOX_DOWNLOAD_TOKEN`.
MAPBOX_DOWNLOAD_TOKEN=sk.REPLACE_ME
